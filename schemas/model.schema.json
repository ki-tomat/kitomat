{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KItomat Model Metadata",
  "allOf": [
    { "$ref": "metadata.schema.json" },
    {
      "type": "object",
      "required": [
        "model_type",
        "target_users",
        "use_case",
        "required_inputs",
        "output_format",
        "application_scope",
        "framework_references",
        "required_review_level"
      ],
      "properties": {
        "artifact_type": { "const": "model" },
        "model_type": { "type": "string", "minLength": 3 },
        "target_users": { "type": "array", "minItems": 1 },
        "use_case": { "type": "string", "minLength": 10 },
        "required_inputs": { "type": "array", "minItems": 1 },
        "output_format": { "type": "string", "minLength": 3 },
        "application_scope": { "type": "string", "minLength": 3 },
        "framework_references": { "type": "array" },
        "required_review_level": { "type": "string", "minLength": 3 }
      }
    }
  ]
}

