{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KItomat Prompt Package Metadata",
  "allOf": [
    { "$ref": "metadata.schema.json" },
    {
      "type": "object",
      "required": [
        "target_users",
        "use_case",
        "required_inputs",
        "output_format",
        "personal_data_possible",
        "evaluation_criteria"
      ],
      "properties": {
        "artifact_type": { "const": "prompt_package" },
        "target_users": { "type": "array", "minItems": 1 },
        "use_case": { "type": "string", "minLength": 10 },
        "required_inputs": { "type": "array", "minItems": 1 },
        "output_format": { "type": "string", "minLength": 3 },
        "personal_data_possible": { "type": "boolean" },
        "evaluation_criteria": { "type": "string", "minLength": 3 }
      }
    }
  ]
}

